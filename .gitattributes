# Normalize line endings to LF on commit, checkout as native
* text=auto

# Force LF for source files
*.js   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.gs   text eol=lf
*.svg  text eol=lf
*.txt  text eol=lf

# Windows scripts keep CRLF
*.bat  text eol=crlf

# Binary assets — no line-ending normalization
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
